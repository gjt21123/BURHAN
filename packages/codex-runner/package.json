{
  "name": "@burhan/codex-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./demo-reset": "./src/demo-reset.ts"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "eval:fixtures": "tsx ../validator-compiler/src/evals/fixture-runner.ts",
    "eval:executor:fixtures": "tsx src/evals/executor-fixtures.ts",
    "eval:execution-verification": "tsx src/evals/execution-verification.ts",
    "diagnose:live-blueprint": "tsx src/evals/live-blueprint-diagnosis.ts",
    "validate:architect-provider-schema": "tsx src/evals/architect-provider-schema.ts",
    "eval:architect-output": "tsx src/evals/architect-output.ts",
    "eval:live-pipeline-continuation": "tsx src/evals/live-pipeline-continuation.ts",
    "eval:live-executor": "tsx src/evals/live-executor-runner.ts",
    "eval:live-executor-finalize": "tsx src/evals/live-executor-finalize.ts",
    "eval:repair-loop": "tsx src/evals/repair-loop.ts",
    "eval:repair-orchestration": "tsx src/evals/repair-orchestration.ts",
    "eval:submission-demo": "tsx src/evals/submission-demo.ts",
    "validate:output-schema": "tsx src/evals/output-schema-preflight.ts",
    "eval:live": "tsx src/evals/live-runner.ts"
  },
  "dependencies": {
    "@burhan/core": "0.1.0",
    "@burhan/validator-compiler": "0.1.0",
    "@burhan/workspace": "0.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.8",
    "zod-to-json-schema": "^3.24.6"
  }
}
